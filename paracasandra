CREATE KEYSPACE nyc311_ks
WITH replication = {
  'class': 'SimpleStrategy',
  'replication_factor': 1
};


CREATE TABLE complaints_by_day (
  complaint_date date PRIMARY KEY,
  total int
);
CREATE TABLE complaints_by_borough (
  borough text PRIMARY KEY,
  total int
);
CREATE TABLE complaints_by_type (
  complaint_type text PRIMARY KEY,
  total int
);
CREATE TABLE complaints_by_status (
  status text PRIMARY KEY,
  total int
);
CREATE TABLE complaints_by_agency_day (
  agency text,
  complaint_date date,
  total int,
  PRIMARY KEY (agency, complaint_date)
) WITH CLUSTERING ORDER BY (complaint_date DESC);


